<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CẤU HÌNH API"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnApiDocs"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:text="📖 TÀI LIỆU API"
            android:backgroundTint="@color/accent_cyan"
            android:textSize="10sp"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="20dp" />

        <!-- Webhook List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_premium"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="URL WEBHOOK"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <Button
                    android:id="@+id/btnAddWebhook"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+ THÊM"
                    android:backgroundTint="#065f46"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/webhookContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btnSaveAll"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="LƯU TẤT CẢ"
                android:backgroundTint="#059669"
                android:layout_marginTop="16dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Token Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_premium"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOKEN CÁ NHÂN"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#020617"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView
                    android:id="@+id/txtToken"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="QUYET_PRIVATE_..."
                    android:textColor="@color/text_white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
                <ImageView
                    android:id="@+id/btnCopyToken"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:padding="8dp"
                    android:background="@drawable/card_bg_premium"
                    android:backgroundTint="@color/accent_cyan" />
            </LinearLayout>

            <Button
                android:id="@+id/btnNewToken"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="TẠO TOKEN MỚI"
                android:backgroundTint="@color/accent_pink"
                android:layout_marginTop="16dp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
